<Window x:Class="StayManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:StayManager.Views.Shared"
        Title="StayManager - Luxe Reserve"
        Height="820"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FAF7F2">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#8A650F"/>
            <Setter Property="BorderBrush" Value="#8A650F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#8A650F"/>
            <Setter Property="Foreground" Value="#8A650F"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TopBar dùng chung cho khu vực khách hàng -->
        <shared:TopBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Hero section -->
                <Grid Height="360">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0F172A" Offset="0"/>
                            <GradientStop Color="#8A650F" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <Grid Width="1040"
                          HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="0.75*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left content -->
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Margin="0,0,40,0">

                            <TextBlock Text="Luxe Reserve"
                                       FontSize="44"
                                       FontWeight="Bold"
                                       FontStyle="Italic"
                                       Foreground="White"/>

                            <TextBlock Text="Hệ thống quản lý và đặt phòng khách sạn"
                                       FontSize="18"
                                       Foreground="#FDE68A"
                                       Margin="0,8,0,24"/>

                            <TextBlock Text="Quản lý phòng, khách hàng, nhân viên, vật tư, đặt trả phòng, hóa đơn và thống kê trong một ứng dụng WPF duy nhất."
                                       FontSize="16"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       LineHeight="28"
                                       Width="560"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,34,0,0">
                                <Button x:Name="btnGoHome"
                                        Content="XEM PHÒNG"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,12,0"/>

                                <Button x:Name="btnGoLogin"
                                        Content="ĐĂNG NHẬP"
                                        Style="{StaticResource OutlineButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right quick panel -->
                        <Border Grid.Column="1"
                                Width="340"
                                Background="White"
                                CornerRadius="10"
                                Padding="22"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                            <StackPanel>
                                <TextBlock Text="Tìm phòng nhanh"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#111827"
                                           Margin="0,0,0,4"/>

                                <TextBlock Text="Chọn ngày lưu trú và số lượng khách."
                                           Foreground="#6B7280"
                                           FontSize="13"
                                           Margin="0,0,0,18"/>

                                <TextBlock Text="Ngày nhận phòng"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <DatePicker x:Name="dpQuickCheckIn"
                                            Height="34"
                                            Margin="0,6,0,14"/>

                                <TextBlock Text="Ngày trả phòng"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <DatePicker x:Name="dpQuickCheckOut"
                                            Height="34"
                                            Margin="0,6,0,14"/>

                                <TextBlock Text="Số khách"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <ComboBox x:Name="cbQuickGuests"
                                          Height="34"
                                          Margin="0,6,0,18">
                                    <ComboBoxItem Content="1 Người"/>
                                    <ComboBoxItem Content="2 Người"/>
                                    <ComboBoxItem Content="3 Người"/>
                                    <ComboBoxItem Content="4 Người"/>
                                </ComboBox>

                                <Button x:Name="btnQuickSearch"
                                        Content="TÌM PHÒNG PHÙ HỢP"
                                        Height="40"
                                        Background="#8A650F"
                                        BorderBrush="#8A650F"
                                        Foreground="White"
                                        FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Main functions -->
                <StackPanel Width="1040"
                            HorizontalAlignment="Center"
                            Margin="0,42,0,50">

                    <TextBlock Text="Chức năng chính"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"
                               TextAlignment="Center"/>

                    <TextBlock Text="Chọn nhanh khu vực làm việc phù hợp với vai trò của bạn."
                               FontSize="13"
                               Foreground="#6B7280"
                               TextAlignment="Center"
                               Margin="0,8,0,28"/>

                    <UniformGrid Columns="3">

                        <!-- Customer area -->
                        <Border Style="{StaticResource CardBorderStyle}"
                                Margin="10"
                                Padding="22">
                            <StackPanel>
                                <Border Height="120"
                                        Background="#D6C4A3"
                                        CornerRadius="6"
                                        Margin="0,0,0,18"/>

                                <TextBlock Text="Khu vực khách hàng"
                                           FontSize="19"
                                           FontWeight="Bold"
                                           Foreground="#111827"/>

                                <TextBlock Text="Xem danh sách phòng, chi tiết phòng, đặt phòng và quản lý hồ sơ cá nhân."
                                           FontSize="13"
                                           Foreground="#6B7280"
                                           TextWrapping="Wrap"
                                           LineHeight="21"
                                           Margin="0,10,0,18"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnOpenHomePage"
                                            Content="Trang chủ"
                                            Height="34"
                                            Width="100"
                                            Background="#8A650F"
                                            BorderBrush="#8A650F"
                                            Foreground="White"
                                            Margin="0,0,8,0"/>

                                    <Button x:Name="btnOpenRoomList"
                                            Content="Danh sách phòng"
                                            Height="34"
                                            Width="130"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Management area -->
                        <Border Style="{StaticResource CardBorderStyle}"
                                Margin="10"
                                Padding="22">
                            <StackPanel>
                                <Border Height="120"
                                        Background="#111827"
                                        CornerRadius="6"
                                        Margin="0,0,0,18"/>

                                <TextBlock Text="Khu vực quản lý"
                                           FontSize="19"
                                           FontWeight="Bold"
                                           Foreground="#111827"/>

                                <TextBlock Text="Dành cho Admin và Staff: quản lý phòng, khách hàng, nhân viên, vật tư, hóa đơn và thống kê."
                                           FontSize="13"
                                           Foreground="#6B7280"
                                           TextWrapping="Wrap"
                                           LineHeight="21"
                                           Margin="0,10,0,18"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnOpenLogin"
                                            Content="Đăng nhập"
                                            Height="34"
                                            Width="100"
                                            Background="#8A650F"
                                            BorderBrush="#8A650F"
                                            Foreground="White"
                                            Margin="0,0,8,0"/>

                                    <Button x:Name="btnOpenDashboard"
                                            Content="Dashboard"
                                            Height="34"
                                            Width="110"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Register area -->
                        <Border Style="{StaticResource CardBorderStyle}"
                                Margin="10"
                                Padding="22">
                            <StackPanel>
                                <Border Height="120"
                                        Background="#9CA3AF"
                                        CornerRadius="6"
                                        Margin="0,0,0,18"/>

                                <TextBlock Text="Tài khoản"
                                           FontSize="19"
                                           FontWeight="Bold"
                                           Foreground="#111827"/>

                                <TextBlock Text="Khách hàng có thể đăng ký tài khoản để đặt phòng nhanh hơn và theo dõi lịch sử lưu trú."
                                           FontSize="13"
                                           Foreground="#6B7280"
                                           TextWrapping="Wrap"
                                           LineHeight="21"
                                           Margin="0,10,0,18"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnOpenRegister"
                                            Content="Đăng ký"
                                            Height="34"
                                            Width="100"
                                            Background="#8A650F"
                                            BorderBrush="#8A650F"
                                            Foreground="White"
                                            Margin="0,0,8,0"/>

                                    <Button x:Name="btnOpenProfile"
                                            Content="Hồ sơ"
                                            Height="34"
                                            Width="100"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <!-- Statistics preview -->
                <Border Width="1040"
                        HorizontalAlignment="Center"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="24"
                        Margin="0,0,0,50">
                    <StackPanel>
                        <TextBlock Text="Tổng quan hệ thống"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   Margin="0,0,0,18"/>

                        <UniformGrid Columns="4">
                            <Border Background="#FAF7F2"
                                    CornerRadius="6"
                                    Padding="16"
                                    Margin="6">
                                <StackPanel>
                                    <TextBlock Text="Tổng số phòng"
                                               Foreground="#6B7280"
                                               FontSize="12"/>
                                    <TextBlock Text="48"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#111827"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FAF7F2"
                                    CornerRadius="6"
                                    Padding="16"
                                    Margin="6">
                                <StackPanel>
                                    <TextBlock Text="Phòng đang sử dụng"
                                               Foreground="#6B7280"
                                               FontSize="12"/>
                                    <TextBlock Text="26"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#111827"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FAF7F2"
                                    CornerRadius="6"
                                    Padding="16"
                                    Margin="6">
                                <StackPanel>
                                    <TextBlock Text="Đặt phòng hôm nay"
                                               Foreground="#6B7280"
                                               FontSize="12"/>
                                    <TextBlock Text="12"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#111827"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FAF7F2"
                                    CornerRadius="6"
                                    Padding="16"
                                    Margin="6">
                                <StackPanel>
                                    <TextBlock Text="Hóa đơn chờ thanh toán"
                                               Foreground="#6B7280"
                                               FontSize="12"/>
                                    <TextBlock Text="7"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#111827"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>   