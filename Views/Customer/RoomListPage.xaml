<Window x:Class="StayManager.Views.Customer.RoomListPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:StayManager.Views.Shared"
        Title="Danh sách phòng"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#FAF7F2">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <shared:TopBar Grid.Row="0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,30,0,50">
                <TextBlock Text="Khám phá không gian nghỉ dưỡng"
                           FontSize="30"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="#111827"/>

                <TextBlock Text="Lựa chọn không gian hoàn hảo cho kỳ nghỉ dưỡng của bạn."
                           FontSize="13"
                           Foreground="#6B7280"
                           TextAlignment="Center"
                           Margin="0,8,0,30"/>

                <Grid Width="760"
                      HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Filter -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="6"
                            Padding="16"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="BỘ LỌC TÌM KIẾM"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Margin="0,0,0,18"/>

                            <TextBlock Text="Mức giá / Đêm"
                                       FontSize="12"
                                       Foreground="#374151"/>

                            <Slider x:Name="slPrice"
                                    Minimum="200"
                                    Maximum="1000"
                                    Value="450"
                                    Margin="0,8,0,18"/>

                            <TextBlock Text="Loại phòng"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <CheckBox Content="Deluxe"
                                      IsChecked="True"
                                      Margin="0,4"/>
                            <CheckBox Content="Premium Suite"
                                      Margin="0,4"/>
                            <CheckBox Content="Ocean Villa"
                                      Margin="0,4"/>
                            <CheckBox Content="Presidential"
                                      Margin="0,4"/>

                            <TextBlock Text="Tiện nghi nổi bật"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,8"/>

                            <CheckBox Content="Ban công riêng"
                                      Margin="0,4"/>
                            <CheckBox Content="Tầm nhìn hướng biển"
                                      IsChecked="True"
                                      Margin="0,4"/>
                            <CheckBox Content="Bồn tắm nước nóng"
                                      Margin="0,4"/>
                            <CheckBox Content="Dịch vụ quản gia"
                                      Margin="0,4"/>

                            <Button x:Name="btnResetFilter"
                                    Content="Thiết lập lại"
                                    Height="32"
                                    Margin="0,18,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Room cards -->
                    <WrapPanel Grid.Column="1"
                               Margin="18,0,0,0">
                        <Border Width="220"
                                Background="White"
                                CornerRadius="6"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="125"
                                        Background="#D6C4A3"
                                        CornerRadius="6,6,0,0"/>
                                <StackPanel Margin="12">
                                    <DockPanel>
                                        <TextBlock Text="Deluxe Ocean View"
                                                   FontWeight="Bold"
                                                   FontSize="15"/>
                                        <TextBlock Text="$350"
                                                   DockPanel.Dock="Right"
                                                   Foreground="#8A650F"
                                                   FontWeight="Bold"/>
                                    </DockPanel>

                                    <TextBlock Text="Không gian mở tràn ngập ánh sáng tự nhiên với ban công riêng tư."
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,10"/>

                                    <TextBlock Text="2 khách   1 giường   45m²"
                                               FontSize="11"
                                               Foreground="#6B7280"/>

                                    <Button x:Name="btnDetailDeluxe"
                                            Content="XEM CHI TIẾT"
                                            Height="30"
                                            Margin="0,12,0,0"
                                            Background="White"
                                            BorderBrush="#8A650F"
                                            Foreground="#8A650F"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Width="220"
                                Background="White"
                                CornerRadius="6"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="125"
                                        Background="#9CA3AF"
                                        CornerRadius="6,6,0,0"/>
                                <StackPanel Margin="12">
                                    <DockPanel>
                                        <TextBlock Text="Premium Suite"
                                                   FontWeight="Bold"
                                                   FontSize="15"/>
                                        <TextBlock Text="$650"
                                                   DockPanel.Dock="Right"
                                                   Foreground="#8A650F"
                                                   FontWeight="Bold"/>
                                    </DockPanel>

                                    <TextBlock Text="Suite cao cấp với phòng khách tách biệt, bồn tắm Jacuzzi."
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,10"/>

                                    <TextBlock Text="2 khách   1 giường   85m²"
                                               FontSize="11"
                                               Foreground="#6B7280"/>

                                    <Button x:Name="btnDetailPremium"
                                            Content="XEM CHI TIẾT"
                                            Height="30"
                                            Margin="0,12,0,0"
                                            Background="White"
                                            BorderBrush="#8A650F"
                                            Foreground="#8A650F"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Width="220"
                                Background="White"
                                CornerRadius="6"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="125"
                                        Background="#111827"
                                        CornerRadius="6,6,0,0"/>
                                <StackPanel Margin="12">
                                    <DockPanel>
                                        <TextBlock Text="Executive Room"
                                                   FontWeight="Bold"
                                                   FontSize="15"/>
                                        <TextBlock Text="$420"
                                                   DockPanel.Dock="Right"
                                                   Foreground="#8A650F"
                                                   FontWeight="Bold"/>
                                    </DockPanel>

                                    <TextBlock Text="Lựa chọn hoàn hảo cho doanh nhân với không gian làm việc rộng rãi."
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,10"/>

                                    <TextBlock Text="2 khách   1 queen   55m²"
                                               FontSize="11"
                                               Foreground="#6B7280"/>

                                    <Button x:Name="btnDetailExecutive"
                                            Content="XEM CHI TIẾT"
                                            Height="30"
                                            Margin="0,12,0,0"
                                            Background="White"
                                            BorderBrush="#8A650F"
                                            Foreground="#8A650F"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>