<Window x:Class="StayManager.Views.Shared.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FAF7F2">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left visual -->
        <Grid Grid.Column="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#8A650F" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center"
                        Margin="70">
                <TextBlock Text="Luxe Reserve"
                           FontSize="38"
                           FontWeight="Bold"
                           FontStyle="Italic"
                           Foreground="White"/>

                <TextBlock Text="Management &amp; Booking System"
                           FontSize="16"
                           Foreground="#FDE68A"
                           Margin="0,8,0,28"/>

                <TextBlock Text="Quản lý đặt phòng, khách hàng, hóa đơn và vận hành khách sạn trong một hệ thống duy nhất."
                           FontSize="17"
                           Foreground="White"
                           TextWrapping="Wrap"
                           LineHeight="28"
                           Width="420"/>
            </StackPanel>
        </Grid>

        <!-- Login form -->
        <Grid Grid.Column="1"
              Background="White">
            <Border Width="390"
                    Padding="34"
                    Background="White"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Đăng nhập"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#111827"/>

                    <TextBlock Text="Chào mừng bạn quay lại Luxe Reserve."
                               FontSize="13"
                               Foreground="#6B7280"
                               Margin="0,8,0,28"/>

                    <TextBlock Text="Tên đăng nhập"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="txtUsername"
                             Height="38"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Mật khẩu"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="txtPassword"
                                 Height="38"
                                 Margin="0,0,0,12"/>

                    <DockPanel Margin="0,0,0,20">
                        <CheckBox x:Name="chkRememberMe"
                                  Content="Ghi nhớ đăng nhập"
                                  FontSize="12"/>

                        <Button x:Name="btnForgotPassword"
                                Content="Quên mật khẩu?"
                                DockPanel.Dock="Right"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="#8A650F"
                                FontSize="12"/>
                    </DockPanel>

                    <Button x:Name="btnLogin"
                            Content="ĐĂNG NHẬP"
                            Height="42"
                            Background="#8A650F"
                            BorderBrush="#8A650F"
                            Foreground="White"
                            FontWeight="Bold"
                            Margin="0,0,0,16"/>

                    <Separator Margin="0,4,0,16"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Chưa có tài khoản?"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="btnGoToRegister"
                                Content="Đăng ký ngay"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="#8A650F"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>