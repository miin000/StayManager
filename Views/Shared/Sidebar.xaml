<UserControl x:Class="StayManager.Views.Shared.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="250" Background="#1F2937">
    <Grid>
        <StackPanel>
            <!-- Logo -->
            <TextBlock Text="Luxe Reserve" FontSize="20" FontWeight="Bold" Foreground="White" Margin="20"/>

            <!-- Search -->
            <TextBox Margin="20" Height="30"/>

            <!-- Menu Items -->
            <StackPanel Margin="10">
                <Button Content="Dashboard" Margin="5" Height="40" Foreground="White" Background="#374151"/>
                <Button Content="Room Status" Margin="5" Height="40" Foreground="White" Background="#374151"/>
                <Button Content="Check-in/Out" Margin="5" Height="40" Foreground="White" Background="#374151"/>
                <Button Content="Staff Management" Margin="5" Height="40" Foreground="White" Background="#374151"/>
                <Button Content="Inventory" Margin="5" Height="40" Foreground="White" Background="#374151"/>
                <Button Content="Billing &amp; Invoices" Margin="5" Height="40" Foreground="White" Background="#374151"/>
                <Button Content="Analytics" Margin="5" Height="40" Foreground="White" Background="#374151"/>
            </StackPanel>

            <!-- Bottom -->
            <StackPanel VerticalAlignment="Bottom" Margin="10">
                <Button Content="Settings" Margin="5" Height="40" Foreground="White" Background="#374151"/>
                <Button Content="Support" Margin="5" Height="40" Foreground="White" Background="#374151"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>