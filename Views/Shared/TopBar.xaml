<UserControl x:Class="StayManager.Views.Shared.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="64">
    <UserControl.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#8A650F"/>
            <Setter Property="BorderBrush" Value="#8A650F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Border Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,0,1">
        <Grid Margin="36,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock Text="Luxe Reserve"
                           FontSize="22"
                           FontWeight="Bold"
                           FontStyle="Italic"
                           Foreground="#0F172A"/>
                <TextBlock Text="Luxury Hotel Booking"
                           FontSize="11"
                           Foreground="#8A650F"/>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button x:Name="btnHome"
                        Content="Trang chủ"
                        Style="{StaticResource NavButtonStyle}"/>

                <Button x:Name="btnRoomList"
                        Content="Phòng"
                        Style="{StaticResource NavButtonStyle}"/>

                <Button x:Name="btnBookingHistory"
                        Content="Đặt phòng"
                        Style="{StaticResource NavButtonStyle}"/>

                <Button x:Name="btnProfile"
                        Content="Hồ sơ"
                        Style="{StaticResource NavButtonStyle}"/>
            </StackPanel>

            <!-- Account -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="btnLogin"
                        Content="Đăng nhập"
                        Style="{StaticResource NavButtonStyle}"/>

                <Button x:Name="btnRegister"
                        Content="Đăng ký"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>