<Window x:Class="StayManager.Views.Management.InvoiceManagementPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StayManager.Views.Shared"
        Title="Quản lý hóa đơn" Height="900" Width="1200">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:Sidebar Grid.Column="0"/>
        <StackPanel Grid.Column="1" Margin="20">
            <TextBlock Text="Danh sách hóa đơn" FontSize="24" FontWeight="Bold" Margin="10"/>
            <ItemsControl x:Name="icInvoices"/>
        </StackPanel>
    </Grid>
</Window>